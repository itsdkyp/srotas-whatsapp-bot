{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Srotas WhatsApp Bot",
  "version": "0.1.0",
  "identifier": "com.srotas.whatsappbot",
  "build": {
    "frontendDist": "dist-placeholder"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "resources/server-app": "server-app"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
