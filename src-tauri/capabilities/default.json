{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-open-external-url",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
