{
  "name": "whatsapp-bot",
  "version": "1.1.7",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron:start": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:ui": "node -e \"const fs=require('fs');['public/dev','public/types','public/.next'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\" && cd frontend && npm install && npm run build",
    "build:win": "npm run build:ui && electron-builder --win --publish never",
    "build:mac": "npm run build:ui && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.srotas.whatsappbot",
    "productName": "Srotas WhatsApp Bot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "!**/.git",
      "!**/.wwebjs_auth",
      "!**/.wwebjs_cache",
      "!**/uploads",
      "!**/data",
      "!dist",
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "guid": "com.srotas.whatsappbot",
      "createDesktopShortcut": "always",
      "deleteAppDataOnUninstall": false,
      "installerSidebar": null
    },
    "mac": {
      "target": [
        "dmg",
        "pkg"
      ],
      "icon": "public/icon.png"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "openai": "^6.22.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^9.0.4"
  }
}